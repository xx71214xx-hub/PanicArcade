* {
    box-sizing: border-box;
    font-family: Tahoma, Arial, sans-serif;
}

body {
    margin: 0;
    background: #0B0C10;
    color: #66FCF1;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow-x: hidden;
    padding: env(safe-area-inset-top, 20px) 15px env(safe-area-inset-bottom, 20px) 15px;
}

/* خلفية النجوم المتحركة الخفيفة */
.stars-bg {
    position: fixed;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, #1f2833 0%, #0b0c10 100%);
    z-index: -1;
}

.hub-container {
    width: 100%;
    max-width: 900px;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.hub-header {
    text-align: center;
    margin-bottom: 40px;
}

.hub-header h1 {
    margin: 0;
    font-size: 42px;
    font-weight: 900;
    letter-spacing: 2px;
    color: #ffffff;
    text-shadow: 0 0 20px rgba(102, 252, 241, 0.4);
}

.hub-header h1 span {
    color: #66FCF1;
}

.hub-subtitle {
    color: #45A29E;
    font-size: 16px;
    margin-top: 10px;
}

/* شبكة الكروت المتجاوبة */
.games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
    width: 100%;
    margin-bottom: 40px;
}

/* كارت اللعبة */
.game-card {
    background: linear-gradient(145deg, #1F2833, #151b24);
    border: 1px solid rgba(102, 252, 241, 0.15);
    border-radius: 24px;
    padding: 30px 20px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease;
}

.game-card.active:hover {
    transform: translateY(-8px);
    border-color: rgba(102, 252, 241, 0.5);
    box-shadow: 0 15px 35px rgba(102, 252, 241, 0.15);
}

/* وهج خلفي خفيف للكروت النشطة */
.card-glow {
    position: absolute;
    width: 150px;
    height: 150px;
    background: #66FCF1;
    filter: blur(120px);
    top: -50px;
    left: -50px;
    opacity: 0.15;
    pointer-events: none;
}

/* شارات الحالة */
.game-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    font-size: 11px;
    font-weight: bold;
    padding: 4px 10px;
    border-radius: 20px;
    background: rgba(0, 255, 170, 0.15);
    color: #00ffaa;
    border: 1px solid rgba(0, 255, 170, 0.3);
}

.game-badge.locked {
    background: rgba(255, 255, 255, 0.05);
    color: #888;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

/* أيقونة اللعبة والمحيط المضيء */
.game-icon-wrapper {
    width: 80px;
    height: 80px;
    background: rgba(31, 40, 51, 0.8);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 20px;
    border: 1px solid rgba(102, 252, 241, 0.2);
    overflow: hidden; /* لمنع تمدد الصورة خارج الدائرة المضيئة */
    box-shadow: 0 0 15px rgba(102, 252, 241, 0.1);
}

.game-icon {
    font-size: 36px;
}

/* التنسيق الجديد لغلاف اللعبة */
.game-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* لضمان ملء الدائرة بشكل متناسق وجميل */
    border-radius: 50%;
}

.game-title {
    margin: 0 0 12px 0;
    font-size: 22px;
    color: #ffffff;
}

.game-desc {
    color: #8f9aa7;
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 25px 0;
    flex-grow: 1;
}

/* أزرار الـ 3D الخاصة بصفحة الهبوط */
.play-btn-3d {
    width: 100%;
    text-decoration: none;
    background: rgba(0, 245, 255, 0.08);
    color: #ffffff;
    font-size: 16px;
    font-weight: bold;
    border: 1px solid rgba(0, 245, 255, 0.3);
    border-top: 2px solid rgba(0, 245, 255, 0.7);
    border-radius: 16px;
    padding: 12px;
    cursor: pointer;
    position: relative;
    transition: all 0.15s ease;
    display: inline-block;
    box-shadow: 
        0 5px 0 rgba(0, 140, 150, 0.8),
        inset 0 1px 2px rgba(255, 255, 255, 0.2),
        0 8px 20px rgba(0, 245, 255, 0.15);
}

.game-card.active:hover .play-btn-3d {
    background: rgba(0, 245, 255, 0.18);
}

.play-btn-3d:active {
    transform: translateY(4px);
    box-shadow: 
        0 1px 0 rgba(0, 140, 150, 0.4),
        inset 0 2px 5px rgba(0,0,0,0.5);
    border-top: 1px solid rgba(0, 245, 255, 0.3);
}

/* الأزرار المغلقة */
.play-btn-3d.disabled {
    background: #1f2833;
    color: #666;
    border: 1px solid rgba(255,255,255,0.05);
    box-shadow: none;
    cursor: not-allowed;
}

.game-card.coming-soon {
    opacity: 0.6;
}

.hub-footer {
    text-align: center;
    color: #45A29E;
    font-size: 12px;
    margin-top: 20px;
}

/* ==========================================================================
   التعديل المضاف: تنسيق شريط تليجرام الاحترافي الجديد (Telegram Profile Bar)
   ========================================================================== */
.tg-profile-bar {
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, rgba(31, 40, 51, 0.75), rgba(11, 12, 16, 0.95));
    border: 1px solid rgba(102, 252, 241, 0.25);
    border-radius: 16px;
    padding: 10px 16px;
    margin: 0 auto 25px auto;
    width: 100%;
    max-width: 440px; 
    box-shadow: 0 4px 20px rgba(0, 245, 255, 0.08), inset 0 1px 2px rgba(255,255,255,0.05);
    gap: 14px;
    box-sizing: border-box;
    direction: rtl;
}

.tg-avatar-wrapper {
    position: relative;
    width: 46px;
    height: 46px;
    flex-shrink: 0;
}

.tg-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #66FCF1;
    box-shadow: 0 0 10px rgba(102, 252, 241, 0.4);
}

.tg-status-dot {
    position: absolute;
    bottom: 1px;
    right: 1px;
    width: 11px;
    height: 11px;
    background: #00ffaa;
    border-radius: 50%;
    border: 2px solid #0B0C10;
    box-shadow: 0 0 6px #00ffaa;
}

.tg-user-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
