.n512  { background:#ff3300; color:white; }
.n1024 { background:#ff6600; color:white; }
.n2048 { background:#ffd900; color:black; }

.controls{
    margin: 10px 0;
    color:#666;
    font-size:12px;
}

.action-bar-3d {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 12px;
    padding: 5px;
    width: 100%;
}

.btn-3d-glass {
    background: rgba(0, 245, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(0, 245, 255, 0.25);
    border-top: 2px solid rgba(0, 245, 255, 0.6);
    border-radius: 16px;
    padding: 10px;
    min-width: 58px;
    height: 54px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    position: relative;
    transition: all 0.15s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: 
        0 5px 0 rgba(0, 168, 181, 0.8),
        inset 0 1px 2px rgba(255, 255, 255, 0.2),
        0 10px 20px rgba(0, 245, 255, 0.15);
}

.btn-3d-glass.undo-layout {
    flex: 1.5;
    max-width: 150px; 
    flex-direction: row;
    gap: 8px;
    background: rgba(0, 245, 255, 0.09);
    border: 1px solid rgba(0, 245, 255, 0.35);
    border-top: 2px solid rgba(0, 245, 255, 0.75);
    box-shadow: 
        0 5px 0 rgba(0, 140, 150, 0.9),
        inset 0 1px 2px rgba(255, 255, 255, 0.3),
        0 10px 25px rgba(0, 245, 255, 0.25);
}

.undo-img-icon {
    width: 22px;
    height: 22px;
    object-fit: contain;
    filter: drop-shadow(0 2px 6px rgba(0, 245, 255, 0.6));
}

.undo-cost {
    font-size: 11px;
    font-weight: bold;
    color: #ffd700;
    text-shadow: 0 1px 3px rgba(0,0,0,0.6);
}

.btn-icon {
    font-size: 18px;
    color: #00f5ff;
    filter: drop-shadow(0 0 5px rgba(0, 245, 255, 0.6));
}

.btn-3d-glass:hover {
    background: rgba(0, 245, 255, 0.15);
    transform: translateY(-1px);
}

.btn-3d-glass:active {
    transform: translateY(4px); 
    box-shadow: 
        0 1px 0 rgba(0, 168, 181, 0.5),
        inset 0 2px 5px rgba(0,0,0,0.5),
        0 2px 5px rgba(0,0,0,0.15);
    border-top: 1px solid rgba(0, 245, 255, 0.3);
}

.popup-box button, .popup-box .reward-btn {
    width: 100%;
    background: rgba(0, 245, 255, 0.08) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #ffffff !important;
    font-size: 15px;
    font-weight: bold;
    border: 1px solid rgba(0, 245, 255, 0.3) !important;
    border-top: 2px solid rgba(0, 245, 255, 0.7) !important;
    border-radius: 16px;
    padding: 14px;
    cursor: pointer;
    position: relative;
    transition: all 0.15s ease;
    display: inline-block;
    box-shadow: 
        0 5px 0 rgba(0, 140, 150, 0.8),
        inset 0 1px 2px rgba(255, 255, 255, 0.2),
        0 8px 20px rgba(0, 245, 255, 0.15) !important;
}

.popup-box button:hover, .popup-box .reward-btn:hover {
    background: rgba(0, 245, 255, 0.18) !important;
}

.popup-box button:active, .popup-box .reward-btn:active {
    transform: translateY(4px);
    box-shadow: 
        0 1px 0 rgba(0, 140, 150, 0.4),
        inset 0 2px 5px rgba(0,0,0,0.5) !important;
    border-top: 1px solid rgba(0, 245, 255, 0.3) !important;
}

body.shake {
    animation: none; 
}
#dangerOverlay.panicFlash {
    animation: softBgPanic 0.8s infinite alternate;
}
@keyframes softBgPanic {
    0% { background: rgba(255, 0, 85, 0); }
    100% { background: rgba(255, 0, 85, 0.15); }
}

#comboWrapper { width: 100%; height: 45px; display: flex; justify-content: center; align-items: center; margin-bottom: 5px; }
#comboBox { display: none; background: linear-gradient(135deg, #251219, #400c1e); border: 2px solid #ff0055; color: white; padding: 4px 20px; border-radius: 20px; text-align: center; }
.popup{ position:fixed; inset:0; background:rgba(0,0,0,.85); display:flex; justify-content:center; align-items:center; z-index:99999; }
.popup-box{ background:linear-gradient(145deg, #253142, #1a2431); padding:22px; border-radius:24px; text-align:center; width:82%; max-width:300px; border:2px solid rgba(102,252,241,.35); }
.reward-container { width: 100%; display: flex; justify-content: center; }
.reward-btn { background: linear-gradient(145deg, #ffd700, #b89200); color: #0b0c10; font-size: 13px; font-weight: bold; border: none; border-radius: 12px; padding: 10px 18px; cursor: pointer; }
.reward-btn:disabled { background: #1f2833; color: #66fcf1; border: 1px solid rgba(102, 252, 241, 0.3); cursor: not-allowed; }

/* ==========================================================================
   الأنماط والمؤثرات المضافة حديثاً للإصلاح والتحسين البصري للعبة
   ========================================================================== */

/* وميض ذهبي مجسم مذهل عند كسب العملات */
.coin-gain {
    animation: goldGlow 0.5s ease-out;
}
@keyframes goldGlow {
    0% { transform: scale(1); box-shadow: 0 0 0 rgba(255, 215, 0, 0); }
    50% { transform: scale(1.1); box-shadow: 0 0 25px rgba(255, 215, 0, 0.8); border-color: #ffd700; }
    100% { transform: scale(1); box-shadow: 0 0 0 rgba(255, 215, 0, 0); }
}

/* حركة انسيابية مرنة (Pop-up) للمربعات المدمجة */
.tile.merge {
    animation: popTile 0.18s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
@keyframes popTile {
    0% { transform: scale(0.85); }
    50% { transform: scale(1.15); }
    100% { transform: scale(1); }
}

/* إضافة نمط زر العودة إلى الصفحة الرئيسية للمنصة (Home Button) */
.home-btn {
    text-decoration: none;
    font-size: 18px;
    background: rgba(102, 252, 241, 0.1);
    border: 1px solid rgba(102, 252, 241, 0.3);
    border-radius: 8px;
    width: 36px;
    height: 36px;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 0 10px rgba(102, 252, 241, 0.05);
    pointer-events: auto; /* تفعيل استجابة سريعة للمس على الجوال */
    
    /* جعل الزر يطفو فوق الطبقة الحاجبة التابعة لـ Popup */
    position: relative;
    z-index: 100000;
}

.home-btn:hover {
    background: rgba(102, 252, 241, 0.25);
    border-color: #66FCF1;
    box-shadow: 0 0 12px rgba(102, 252, 241, 0.3);
    transform: scale(1.05);
}

.home-btn:active {
    transform: scale(0.95);
    background: rgba(102, 252, 241, 0.4);
}
